#!/usr/bin/env bash
# media-converter - NEW VERSION WITH PYTHON CLI
# Uses Python CLI with Rich interface and structured logging

# Resolve the real script path, even when called via symlink
REAL_SCRIPT_PATH="$(readlink -f "$0")"
PROJECT_DIR="$(dirname "$REAL_SCRIPT_PATH")"

# Change to project directory
cd "$PROJECT_DIR" || {
    echo "Error: Could not access project directory: $PROJECT_DIR" >&2
    exit 1
}

# Check and activate virtual environment
if [ -d "venv" ] && [ -f "venv/bin/activate" ]; then
    source venv/bin/activate
fi

# Execute the CLI manager
# If no arguments provided, default to interactive mode
if [ $# -eq 0 ]; then
    exec python3 scripts/cli_manager.py "interactive"
else
    exec python3 scripts/cli_manager.py "$@"
fi
