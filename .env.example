# =============================================================================
# MEDIA CONVERTER - CONFIGURATION
# =============================================================================
# Copy this file to .env and adjust values as needed.
# All values have sensible defaults if not specified.

# =============================================================================
# CONVERSION DEFAULTS
# =============================================================================
# Default image format: JPEG or PNG
IMAGE_FORMAT=JPEG

# Default video codec: h264, h265, or copy
VIDEO_CODEC=h264

# Default video quality: auto, lossless, high, or medium
VIDEO_QUALITY=auto

# Default resize option: 4k, 2k, 1440p, 1080p, or none
RESIZE=none

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================
# Maximum concurrent workers for image conversion
MAX_WORKERS_IMAGES=4

# Maximum concurrent workers for video conversion
MAX_WORKERS_VIDEOS=2

# CPU usage threshold percentage (pause if exceeded)
CPU_THRESHOLD_PERCENT=80

# Memory usage threshold percentage (pause if exceeded)
MEMORY_THRESHOLD_PERCENT=85

# Monitor system resources during conversion
MONITOR_SYSTEM_RESOURCES=true

# =============================================================================
# CACHE SETTINGS
# =============================================================================
# Maximum number of entries in ffprobe cache
MAX_CACHE_SIZE=1000

# Cache expiration time in minutes
CACHE_EXPIRE_MINUTES=60

# =============================================================================
# SAFETY SETTINGS
# =============================================================================
# Maximum retries for failed conversions
MAX_RETRIES=3

# Safety factor for disk space estimation (1.5 = require 50% extra space)
DISK_SPACE_SAFETY_FACTOR=1.5

# Enable automatic cleanup of temporary files
TEMP_CLEANUP_ENABLED=true

# =============================================================================
# CUSTOM FFMPEG PARAMETERS (JSON format)
# =============================================================================
# Additional ffmpeg parameters for video conversion
# Example: CUSTOM_FFMPEG_PARAMS={"preset": "slow", "tune": "film"}
CUSTOM_FFMPEG_PARAMS={}

# Additional parameters for image conversion
# Example: CUSTOM_IMAGE_PARAMS={"optimize": true}
CUSTOM_IMAGE_PARAMS={}

# =============================================================================
# LOGGING
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable file logging
LOG_TO_FILE=true

# Log file location (relative to project root)
LOG_FILE=logs/media_converter.log

# =============================================================================
# CONVERSION DATABASE
# =============================================================================
# JSON database that stores conversion history and output paths
CONVERSION_DB_FILE=data/conversion_db.json
